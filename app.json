{
  "expo": {
    "name": "뇽파민",
    "slug": "nyong-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "nyongpamin",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nyong.app",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FCE4EC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nyong.app",
      "versionCode": 30,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "com.google.android.gms.permission.AD_ID"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/nyong_paw.png",
          "color": "#E88B99"
        }
      ],
      "expo-font",
      "expo-updates",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "광고 맞춤화를 위해 사용됩니다. 허용하면 더 관련성 높은 광고를 볼 수 있어요."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4591317861924477~8090446533",
          "iosAppId": "ca-app-pub-4591317861924477~7779537491"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/b7354b39-b61c-4470-bbc5-f5fab6a0d32b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b7354b39-b61c-4470-bbc5-f5fab6a0d32b"
      },
      "router": {}
    }
  }
}
